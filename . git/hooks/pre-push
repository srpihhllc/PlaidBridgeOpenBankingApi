# home/srpihhllc/PlaidBridgeOpenBankingApi/. git/hooks/pre-push


#!/bin/bash

# --- CONFIGURATION ---
URL="https://YOUR_DOMAIN.com/diagnostics/full"
USER="admin"
PASS="password"
TIMEOUT=10

# --- UI COLORS ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🛰️  Executing Neural Pulse Pre-Push Check...${NC}"

# 1. ATTEMPT CONNECTION
# We use --max-time to ensure a slow server doesn't block your workflow
RESPONSE=$(curl -s -u "$USER":"$PASS" --max-time $TIMEOUT "$URL")
CURL_EXIT_CODE=$?

if [ $CURL_EXIT_CODE -ne 0 ]; then
    echo -e "${RED}❌ CONNECTION ERROR: Could not reach the diagnostics API (Code: $CURL_EXIT_CODE).${NC}"
    echo "Check your internet connection or PythonAnywhere status."
    exit 1
fi

# 2. VALIDATE JSON
if ! echo "$RESPONSE" | jq -e . >/dev/null 2>&1; then
    echo -e "${RED}❌ FORMAT ERROR: Received invalid response from server.${NC}"
    exit 1
fi

# 3. EXTRACT METRICS
DB_ONLINE=$(echo "$RESPONSE" | jq -r '.infra.database.online')
SYNCED=$(echo "$RESPONSE" | jq -r '.integrity.synced')
VERSION=$(echo "$RESPONSE" | jq -r '.meta.app_version')

# 4. ENFORCE RULES
# Rule A: Database must be online
if [ "$DB_ONLINE" != "true" ]; then
    echo -e "${RED}❌ CRITICAL FAILURE: Production Database is OFFLINE.${NC}"
    echo "Aborting push to prevent cascading failures."
    exit 1
fi

# Rule B: Migrations must be synced (The App Developer's Safety Net)
if [ "$SYNCED" != "true" ]; then
    echo -e "${YELLOW}⚠️  INTEGRITY ALERT: Production is out of sync (Migration Drift).${NC}"
    echo "Your local code may rely on schema changes not yet present in Production."
    echo -n "Do you want to push anyway? (y/n): "
    read -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}Push aborted by user.${NC}"
        exit 1
    fi
fi

echo -e "${GREEN}✅ NEURAL PULSE GREEN (v$VERSION). Proceeding with push...${NC}"
exit 0