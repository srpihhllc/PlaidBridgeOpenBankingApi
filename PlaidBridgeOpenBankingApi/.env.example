# .env.example - sanitized placeholders only
# DO NOT commit real secrets into the repository.
# Store real credentials in your deployment environment or GitHub Secrets.

# --------------------------------------------
# Plaid API Credentials
# --------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_LINK_TOKEN=your_dynamic_token_if_applicable
PLAID_PUBLIC_KEY=your_public_key_if_needed

# --------------------------------------------
# Treasury Prime Configuration
# --------------------------------------------
TREASURY_PRIME_SANDBOX_API_KEY=your_treasuryprime_sandbox_key
TREASURY_PRIME_PRODUCTION_API_KEY=your_treasuryprime_production_key
TREASURY_PRIME_SANDBOX_API_URL=https://api.sandbox.treasuryprime.com
TREASURY_PRIME_PRODUCTION_API_URL=https://api.treasuryprime.com
TREASURY_PRIME_ENV=sandbox

# --------------------------------------------
# User & Account Settings (example placeholders)
# --------------------------------------------
CLIENT_USER_ID=your_client_user_id
USER_EMAIL=your_user_email
USER_PASSWORD=your_user_password
ACCOUNT_NUMBER=your_account_number
MOCK_USERNAME=your_mock_username
MOCK_PASSWORD=your_mock_password

# --------------------------------------------
# Flask Configuration
# --------------------------------------------
FLASK_APP=app.py
FLASK_RUN_HOST=0.0.0.0
FLASK_ENV=development
FLASK_DEBUG=False
PORT=5000
LOG_LEVEL=INFO

# --------------------------------------------
# MySQL Database Configuration (placeholders)
# --------------------------------------------
DB_USER=your_db_user
DB_PASSWORD=REPLACE_WITH_ENV_SECRET
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_PORT=3306

# Recommended: build connection strings at runtime from env vars.
# Example (do not commit actual connection strings with secrets):
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --------------------------------------------
# Security Keys (placeholders)
# --------------------------------------------
SECRET_KEY=your_flask_secret_key
JWT_SECRET_KEY=your_jwt_secret_key

# --------------------------------------------
# Redis (placeholder)
# --------------------------------------------
REDIS_STORAGE_URI=redis://:your_redis_password@your_redis_host:6379/0

# --------------------------------------------
# Email Configuration (placeholders)
# --------------------------------------------
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_DEFAULT_SENDER_NAME=PlaidBridge Open Banking API

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# Comma-separated values, e.g. "200 per day,50 per hour"
LIMITER_DEFAULTS=200 per day,50 per hour

# -----------------------------------------------------------------------------
# Notes:
# - Replace placeholders with real values via your environment/secret manager.
# - For GitHub Actions: set repository or environment secrets, then reference them in workflows.
# - After history scrubbing, push only sanitized examples; never reintroduce secrets.
# -----------------------------------------------------------------------------
