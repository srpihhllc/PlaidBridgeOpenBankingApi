# /home/srpihhllc/PlaidBridgeOpenBankingApi/.env.example

# --------------------------------------------
# Plaid API Credentials
# --------------------------------------------
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_LINK_TOKEN=your_dynamic_token_if_applicable
PLAID_PUBLIC_KEY=your_public_key_if_needed

# --------------------------------------------
# Treasury Prime Configuration
# --------------------------------------------
TREASURY_PRIME_SANDBOX_API_KEY=your_treasuryprime_sandbox_key
TREASURY_PRIME_PRODUCTION_API_KEY=your_treasuryprime_production_key
TREASURY_PRIME_SANDBOX_API_URL=https://api.sandbox.treasuryprime.com
TREASURY_PRIME_PRODUCTION_API_URL=https://api.treasuryprime.com
TREASURY_PRIME_ENV=sandbox

# --------------------------------------------
# User & Account Settings
# --------------------------------------------
CLIENT_USER_ID=your_client_user_id
USER_EMAIL=your_user_email
USER_PASSWORD=your_user_password
ACCOUNT_NUMBER=your_account_number
MOCK_USERNAME=your_mock_username
MOCK_PASSWORD=your_mock_password

# --------------------------------------------
# Flask Configuration
# --------------------------------------------
FLASK_APP=app.py
FLASK_RUN_HOST=0.0.0.0
FLASK_ENV=development
FLASK_DEBUG=False
PORT=5000
LOG_LEVEL=INFO

# =============================================================================
# FILE: .env
# DESCRIPTION: Environment configuration for MySQL + Redis + Cosmos
# =============================================================================

# =============================================================================
# FILE: .env
# DESCRIPTION: Environment configuration for MySQL + Redis + Cosmos
#              Explicit, cockpit‑grade layout with comments for operators.
# =============================================================================

# -------------------------------------------------------------------
# MySQL Database Configuration
# -------------------------------------------------------------------
DB_USER=srpihhllc
DB_PASSWORD=your_db_password
DB_HOST=srpihhllc.mysql.pythonanywhere-services.com
DB_NAME=srpihhllc$default
DB_PORT=3306
SQLALCHEMY_DATABASE_URI="mysql+pymysql://your_db_user:your_db_password@your_db_host:3306/your_db_name"

# --------------------------------------------
# Security Keys
# --------------------------------------------
SECRET_KEY=your_flask_secret_key
JWT_SECRET_KEY=your_jwt_secret_key

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_STORAGE_URI=redis://:your_redis_password@your_redis_host:6379/0

# --------------------------------------------
# Email Configuration
# --------------------------------------------
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_DEFAULT_SENDER_NAME=PlaidBridge Open Banking API

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
# Comma-separated values, e.g. "200 per day, 50 per hour"
LIMITER_DEFAULTS=200 per day,50 per hour

