# PlaidBridgeOpenBankingApi - combined .env.example (sanitized)
# IMPORTANT: This file contains placeholders only. Do NOT commit real secrets.
# Use your deployment environment or secret manager to provide real values.

# -----------------------
# App / Flask
# -----------------------
FLASK_APP=run.py
FLASK_ENV=production        # or "development"
FLASK_DEBUG=False
PORT=3000
LOG_LEVEL=INFO

# -----------------------
# Security keys
# -----------------------
SECRET_KEY=replace_with_secure_random_string
JWT_SECRET_KEY=replace_with_secure_random_string

# -----------------------
# Plaid
# -----------------------
PLAID_CLIENT_ID=replace_with_plaid_client_id
PLAID_SECRET=replace_with_plaid_secret
PLAID_PUBLIC_KEY=replace_with_plaid_public_key
PLAID_ENV=sandbox           # or "production"

# -----------------------
# Treasury Prime
# -----------------------
TREASURY_PRIME_SANDBOX_API_KEY=replace_with_treasuryprime_sandbox_key
TREASURY_PRIME_PRODUCTION_API_KEY=replace_with_treasuryprime_production_key
TREASURY_PRIME_SANDBOX_API_URL=https://api.sandbox.treasuryprime.com
TREASURY_PRIME_PRODUCTION_API_URL=https://api.treasuryprime.com
TREASURY_PRIME_ENV=sandbox

# -----------------------
# OAuth / External apps
# -----------------------
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# -----------------------
# Database (MySQL) - placeholders
# -----------------------
DB_USER=replace_with_db_user
DB_PASSWORD=replace_with_db_password
DB_HOST=replace_with_db_host                # e.g. srpihhllc.mysql.pythonanywhere-services.com
DB_PORT=3306
DB_NAME=replace_with_db_name

# Optional: application can build connection string at runtime from above variables.
# Do NOT put credentials directly into a committed URI.
# Example (do not commit): SQLALCHEMY_DATABASE_URI=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
SQLALCHEMY_DATABASE_URI=replace_with_sqlalchemy_database_uri_if_needed

# -----------------------
# Redis
# -----------------------
# Canonical name used here: REDIS_STORAGE_URI
REDIS_STORAGE_URI=redis://:replace_with_redis_password@replace_with_redis_host:6379/0
# If your code expects REDIS_URL, map it from REDIS_STORAGE_URI in runtime config.

# -----------------------
# Cosmos / other datastores
# -----------------------
COSMOS_DB_CONNECTION_STRING=replace_with_cosmos_connection_string

# -----------------------
# Application / demo accounts and credentials
# -----------------------
CLIENT_USER_ID=replace_with_client_user_id
USER_EMAIL=replace_with_user_email
USER_PASSWORD=replace_with_user_password
ACCOUNT_NUMBER=replace_with_account_number

# Mock/demo accounts
MOCK_USERNAME=replace_with_mock_username
MOCK_PASSWORD=replace_with_mock_password

# -----------------------
# API keys / other secrets
# -----------------------
API_KEY=replace_with_api_key
API_SECRET=replace_with_api_secret

# -----------------------
# Notes
# -----------------------
# - Rotate any credentials that were exposed in commits immediately.
# - Provide real secrets via your environment, GitHub Secrets, or a secret manager.
# - Enable secret scanning and pre-commit secret detection to prevent future leaks.
# - After you scrub history, re-run secret scanning and delete any remote refs that still contain secrets.
